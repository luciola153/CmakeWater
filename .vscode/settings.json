{
  // For CMake Tools extension: provides GUI buttons (Configure/Build) in the status bar.
  "cmake.generator": "Ninja",
  "cmake.buildDirectory": "${workspaceFolder}/build",
  "cmake.configureOnOpen": false,
  // Make clangd use CMake's exact compile flags/includes for this project.
  "clangd.arguments": [
    "--compile-commands-dir=${workspaceFolder}/build/Debug"
  ]
}

